{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "X-Frame-Options", "value": "DENY"},
        {"key": "X-Content-Type-Options", "value": "nosniff"},
        {"key": "Referrer-Policy", "value": "strict-origin-when-cross-origin"},
        {"key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()"}
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {"key": "Content-Type", "value": "application/xml"}
      ]
    }
  ],
  "redirects": [
    {"source": "/manneinfluensa", "destination": "/hva-er-manneinfluensa", "statusCode": 301},
    {"source": "/manflu", "destination": "/hva-er-manneinfluensa", "statusCode": 301},
    {"source": "/behandling", "destination": "/hva-hjelper-mot-manflu", "statusCode": 301},
    {"source": "/varighet", "destination": "/hvor-lenge-varer-manflu", "statusCode": 301},
    {"source": "/smitte", "destination": "/influensa-smittsom", "statusCode": 301},
    {"source": "/immunforsvaret", "destination": "/immunforsvar", "statusCode": 301},
    {"source": "/faq", "destination": "/#faq", "statusCode": 301}
  ]
}
